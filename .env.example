# NEON TIDE - environment (all optional for local dev; required in prod)

# Telegram bot token from @BotFather (bot: @lodkabuildbot). REQUIRED in production.
BOT_TOKEN=

# Bot @username without the @ (used in logs / links).
BOT_USERNAME=lodkabuildbot

# Public HTTPS URL of this service. On Railway this is auto-derived from
# RAILWAY_PUBLIC_DOMAIN, so you usually don't need to set it.
APP_URL=

# Random string - the Telegram webhook path is /bot/<WEBHOOK_SECRET>.
WEBHOOK_SECRET=change-me-to-something-random

# HTTP port (Railway injects this automatically).
PORT=8080

# Game is Game hub base URL. Baked into the client bundle at BUILD time (vite
# envPrefix GG_), read as import.meta.env.GG_HUB_URL in src/gg.ts. When set and
# the app is launched from the hub (startapp token present), the gold balance IS
# the hub wallet G: read via ggBalance, spent via ggSpend. Empty -> local-only
# balance (standalone play still works). Example: https://hub.gameisgame.example
GG_HUB_URL=
